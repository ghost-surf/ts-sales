DATABASE_URL="mysql://user:password@localhost:3306/hydrostock"

PORT=4000

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=30

CORS_ORIGIN="http://localhost:8080"

SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_EMAIL="admin@carecatech.co.mz"
SEED_ADMIN_PASSWORD="Admin1234"

# URL pública do frontend, usada para gerar links dentro dos emails de notificação
APP_URL="http://localhost:8080"

# Resend (https://resend.com) para envio de notificações (stock baixo, faturas vencidas, notas de crédito).
# Envia por API HTTPS em vez de SMTP (a maioria dos provedores cloud bloqueia as portas SMTP de saída).
# Se RESEND_API_KEY ficar vazio, as notificações são apenas registadas no log, sem enviar email.
RESEND_API_KEY=""
SMTP_FROM="TS Sales <no-reply@carecatech.co.mz>"
