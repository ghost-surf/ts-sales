DATABASE_URL="mysql://user:password@localhost:3306/hydrostock"

PORT=4000

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=30

CORS_ORIGIN="http://localhost:8080"

SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_EMAIL="admin@carecatech.co.mz"
SEED_ADMIN_PASSWORD="Admin1234"

# URL pública do frontend, usada para gerar links dentro dos emails de notificação
APP_URL="http://localhost:8080"

# SMTP para envio de notificações (stock baixo, faturas vencidas, notas de crédito).
# Se SMTP_HOST ficar vazio, as notificações são apenas registadas no log, sem enviar email.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="TS Sales <no-reply@carecatech.co.mz>"
